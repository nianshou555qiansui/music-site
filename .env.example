# 服务端口
PORT=3000

# 开发/生产环境。公网部署建议设置 NODE_ENV=production 和 PUBLIC_DEPLOY=true
NODE_ENV=development
PUBLIC_DEPLOY=false

# 生产环境必须改成足够长的随机字符串
JWT_SECRET=change-me-to-a-long-random-secret

# 生产环境建议设置为你的站点域名，例如 https://music.example.com
# 多个域名用英文逗号分隔；开发环境可保留 *
CORS_ORIGIN=*

# 注册邀请码兼容种子。首次启动时如果数据库还没有邀请码，会导入这一个码；之后请用 npm run invite 管理多邀请码
# REGISTER_INVITE_CODE=change-me-to-random-alphanumeric-code

# 音乐接口相关变量（需自行配置，不配置则自动跳过）
# KARPOV_BASE_URL=
# KARPOV_API_KEY=
# GDSTUDIO_BASE_URL=
# GDSTUDIO_ENABLED=true
